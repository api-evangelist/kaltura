      "enum": [
        "NotSent",
        "Sending",
        "Sent",
        "Aborted"
      ],
      "readOnly": true,
      "type": "string",
      "x-enumLabels": [
        "NOTSENT",
        "SENDING",
        "SENT",
        "ABORTED"
      ],
      "x-enumType": "KalturaAnnouncementStatus"
    },
    "timezone": {
      "description": "Announcement time zone",
      "type": "string"
    }
